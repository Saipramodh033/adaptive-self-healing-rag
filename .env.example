# ── LLM Provider ──────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
# For production/adaptive RAG
GROQ_API_KEY=your_groq_api_key_here

# ── LangSmith Evaluation ───────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://apac.api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_your_langsmith_api_key_here
LANGCHAIN_PROJECT=Adaptive-RAG-Benchmarking

# For evaluation benchmarking (Phase 9) - prevents rate limits by splitting traffic
GROQ_API_KEY_TRAD=your_second_groq_key_here
GROQ_API_KEY_JUDGE=your_third_groq_key_here
# ── Model Selection ────────────────────────────────────────────────────────────
# Fast model: handles routing, grading, fact-checking (8B — 14,400 RPD free tier)
FAST_MODEL=llama-3.1-8b-instant

# Power model: final response synthesis only (70B — 1,000 RPD free tier)
POWER_MODEL=llama-3.3-70b-versatile

# ── Groq 70B Daily Budget Guard ────────────────────────────────────────────────
# Free tier caps llama-3.3-70b-versatile at 1,000 requests/day.
# System warns at 80% usage and gracefully falls back to 8B at this limit.
# Set to 950 to leave a 50-request safety buffer.
POWER_MODEL_DAILY_BUDGET=950

# ── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=ecommerce_support

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Local CPU-only model: 384-dim, ~133MB disk, ~300-600MB RAM at runtime
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Self-Healing Retry Budgets ─────────────────────────────────────────────────
# Max query rewrites before escalating to human agent
MAX_QUERY_REWRITES=3

# Max response regenerations before escalating to human agent
MAX_GENERATION_RETRIES=2

# ── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50
